{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProductListing",
  "type": "object",
  "required": ["sku", "title", "subtitle", "long_description", "bullets", "seo_title", "seo_meta_description"],
  "additionalProperties": false,
  "properties": {
    "sku": { "type": "string" },
    "title": { "type": "string", "minLength": 4, "maxLength": 80 },
    "subtitle": { "type": "string", "minLength": 4, "maxLength": 140 },
    "long_description": { "type": "string", "minLength": 80, "maxLength": 1200 },
    "bullets": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "type": "string", "minLength": 6, "maxLength": 100 }
    },
    "seo_title": { "type": "string", "maxLength": 60 },
    "seo_meta_description": { "type": "string", "maxLength": 155 }
  }
}
