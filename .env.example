# --- Marketing site (Next.js, ./app) ---
DATABASE_URL=postgres://...neon...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Set to "true" only after CEO security sign-off. With sk_live_ key + this
# flag set, checkout charges real cards. Anything else = TEST mode.
STRIPE_LIVE_MODE=false
# Stripe price IDs created out-of-band. Empty = pricing buttons jump to
# the waitlist anchor instead of /api/checkout.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ONETIME=
RESEND_API_KEY=re_...
PUBLIC_URL=http://localhost:3000
TRIAGEPACK_RELEASE_URL=

# --- Agent (Python, ./agent) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
# Required: HMAC-SHA256 shared value PagerDuty signs webhook bodies with.
# /v1/incidents rejects every POST when this is unset.
PAGERDUTY_WEBHOOK_SECRET=

# Pick one logs backend:
LOKI_URL=
DATADOG_API_KEY=
DATADOG_APP_KEY=

# Pick one runbook backend:
NOTION_TOKEN=
NOTION_DATABASE_ID=
RUNBOOK_DIR=

# JSON object: {"checkout-api": "acme/checkout", "billing-api": "acme/billing"}
SERVICE_REPO_MAP=
SERVICE_REPO_MAP_PATH=

# Triage tuning
CONFIDENCE_FLOOR=0.6

# Optional: point spans somewhere
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=triagepack
